---
import Favicons from "$components/Favicons.astro";
import Header from "$components/Header.astro";
import SEO from "$components/SEO.astro";

interface Props {
	title: string;
	description: string | undefined;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head class="max-h-full">
		<meta charset="UTF-8" />

		<link
			rel="sitemap"
			href="/sitemap-index.xml"
		/>

		<meta
			name="viewport"
			content="width=device-width"
		/>

		<Favicons />

		<SEO
			{title}
			{description}
		/>

		<title>{title}</title>
	</head>

	<body
		class="flex flex-col items-center prose prose-invert bg-base max-w-full max-h-full"
	>
		<Header />

		<div class="max-w-prose min-height-[100dvh] flex-grow">
			<slot />
		</div>
	</body>
</html>
